{
	"name": "gh",
	"version": "0.0.0-example",
	"private": true,
	"description": "A minimal GitHub CLI clone — dreamcli walkthrough example",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/dreamcli.git",
		"directory": "examples/gh"
	},
	"type": "module",
	"module": "src/main.ts",
	"bin": {
		"gh": "src/main.ts"
	},
	"files": [
		"src",
		"!src/**/*.test.ts"
	],
	"scripts": {
		"bd": "bun run build",
		"build": "bun build src/main.ts --install --outdir=dist --format=esm --target=node --external @kjanat/dreamcli",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@kjanat/dreamcli": "link:@kjanat/dreamcli"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.11",
	"engines": {
		"bun": ">=1.3"
	},
	"devEngines": {
		"runtime": {
			"name": "bun",
			"version": ">=1.3",
			"onFail": "error"
		}
	}
}
