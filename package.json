{
	"name": "dreamcli",
	"version": "0.9.1",
	"description": "Schema-first, fully typed TypeScript CLI framework",
	"keywords": [],
	"homepage": "https://github.com/kjanat/dreamcli#readme",
	"bugs": {
		"url": "https://github.com/kjanat/dreamcli/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/dreamcli.git"
	},
	"license": "MIT",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./runtime": {
			"bun": "./src/runtime.ts",
			"import": "./dist/runtime.mjs",
			"require": "./dist/runtime.cjs"
		},
		"./testkit": {
			"bun": "./src/testkit.ts",
			"import": "./dist/testkit.mjs",
			"require": "./dist/testkit.cjs"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"files": [
		"dist",
		"src",
		"!src/**/*.test.ts"
	],
	"scripts": {
		"build": "tsdown",
		"check": "tsgo --noEmit",
		"check:tsc": "tsc --noEmit",
		"ci": "bun check && bun lint && bun run test && bun run build",
		"format": "dprint fmt",
		"format:check": "dprint check",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"prepack": "bun run build",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@arethetypeswrong/core": "^0.18.2",
		"@biomejs/biome": "^2.3.14",
		"@types/bun": "^1.3.8",
		"@types/node": "^24.10.13",
		"@typescript/native-preview": "^7.0.0-dev.20260211.1",
		"@vitest/coverage-v8": "^4.0.18",
		"dprint": "^0.51.1",
		"publint": "^0.3.17",
		"tsdown": "^0.20.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"packageManager": "bun@1.3.9",
	"engines": {
		"bun": ">=1.3",
		"deno": ">=2.6",
		"node": ">=22"
	},
	"publishConfig": {
		"exports": {
			".": {
				"import": "./dist/index.mjs",
				"require": "./dist/index.cjs"
			},
			"./runtime": {
				"import": "./dist/runtime.mjs",
				"require": "./dist/runtime.cjs"
			},
			"./testkit": {
				"import": "./dist/testkit.mjs",
				"require": "./dist/testkit.cjs"
			},
			"./package.json": "./package.json"
		}
	}
}
