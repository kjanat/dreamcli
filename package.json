{
	"name": "dreamcli",
	"version": "0.7.0",
	"description": "Schema-first, fully typed TypeScript CLI framework",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./runtime": {
			"import": "./dist/runtime.mjs",
			"require": "./dist/runtime.cjs"
		},
		"./testkit": {
			"import": "./dist/testkit.mjs",
			"require": "./dist/testkit.cjs"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsdown",
		"check": "tsgo --noEmit",
		"check:tsc": "tsc --noEmit",
		"ci": "bun check && bun lint && bun run test && bun run build",
		"format": "dprint fmt",
		"format:check": "dprint check",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@arethetypeswrong/core": "^0.18.2",
		"@biomejs/biome": "^2.3.14",
		"@typescript/native-preview": "^7.0.0-dev.20260209.1",
		"@vitest/coverage-v8": "^4.0.18",
		"dprint": "^0.51.1",
		"publint": "^0.3.17",
		"tsdown": "^0.20.3",
		"typescript": "^5",
		"vitest": "^4.0.18"
	},
	"packageManager": "bun@1.3.9",
	"engines": {
		"node": ">=20"
	}
}
