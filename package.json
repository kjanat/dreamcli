{
	"name": "dreamcli",
	"version": "0.9.1",
	"description": "Schema-first, fully typed TypeScript CLI framework",
	"keywords": [
		"cli",
		"typescript",
		"framework",
		"schema-first",
		"command-line"
	],
	"homepage": "https://dreamcli.kjanat.com",
	"bugs": {
		"url": "https://github.com/kjanat/dreamcli/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/dreamcli.git"
	},
	"license": "MIT",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./runtime": {
			"import": "./dist/runtime.mjs",
			"require": "./dist/runtime.cjs"
		},
		"./testkit": {
			"import": "./dist/testkit.mjs",
			"require": "./dist/testkit.cjs"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"files": [
		"README.md",
		"LICENSE",
		"CHANGELOG.md",
		"package.json",
		"dist",
		"examples",
		"src",
		"!src/**/*.test.ts"
	],
	"scripts": {
		"bd": "bun --bun run build",
		"build": "tsdown",
		"ci": "bun typecheck && bun lint && bun run test && bun bd",
		"docs:build": "vitepress build docs",
		"docs:dev": "vitepress dev docs",
		"docs:preview": "vitepress preview docs",
		"fmt": "dprint fmt",
		"format": "dprint fmt",
		"format:check": "dprint check",
		"lint": "biome lint",
		"lint:fix": "biome lint --fix",
		"prepack": "bun bd",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsgo --noEmit",
		"typecheck:tsc": "tsc --noEmit",
		"upgrade": "bun update --latest && bun add -D vitepress@next"
	},
	"overrides": {
		"@types/node": "22.0.0"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "0.18.2",
		"@arethetypeswrong/core": "0.18.2",
		"@biomejs/biome": "2.4.10",
		"@types/bun": "1.3.11",
		"@types/deno": "2.5.0",
		"@types/node": "22.0.0",
		"@typescript/native-preview": "7.0.0-dev.20260331.1",
		"@vitest/coverage-v8": "4.1.2",
		"dprint": "0.53.1",
		"mermaid": "11.13.0",
		"publint": "0.3.18",
		"tsdown": "0.21.7",
		"typescript": "6.0.2",
		"vitepress": "2.0.0-alpha.17",
		"vitepress-plugin-mermaid": "2.0.17",
		"vitest": "4.1.2"
	},
	"packageManager": "bun@1.3.11",
	"engines": {
		"bun": ">=1.3",
		"deno": ">=2.6",
		"node": ">=22"
	},
	"volta": {
		"node": "25.8.2",
		"npm": "11.12.1"
	}
}
