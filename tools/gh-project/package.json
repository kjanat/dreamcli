{
	"name": "@kjanat/gh-project",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"bin": {
		"gh-project": "src/main.ts"
	},
	"files": [
		"src"
	],
	"imports": {
		"#gh-project": "./src/index.ts",
		"#lib/*": "./src/lib/*",
		"#commands/*": "./src/commands/*"
	},
	"scripts": {
		"start": "bun src/main.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@kjanat/dreamcli": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"typescript": "catalog:"
	}
}
