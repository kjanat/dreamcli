// Folder-specific settings
//
// For a full list of overridable settings, and general information on folder-specific settings,
// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
{
	"hard_tabs": true,
	"tab_size": 2,
	"wrap_guides": [100],
	"file_types": { "Markdown": ["LICENSE"] },
	"prettier": { "allowed": false },
	"formatter": [
		{ "language_server": { "name": "dprint" } },
		// Fallback to the dprint CLI in case the lsp fucks up, which it does sometimes for some reason...
		{ "external": { "command": "dprint", "arguments": ["fmt", "--stdin", "{buffer_path}"] } }
	],
	"languages": {
		"JavaScript": {
			"code_actions_on_format": {
				"fixAll.biome": true,
				"organizeImports.biome": true
			},
			"language_servers": ["vtsls", "tsgo", "biome", "deno"]
		},
		"TypeScript": {
			"code_actions_on_format": {
				"fixAll.biome": true,
				"organizeImports.biome": true
			},
			"language_servers": ["vtsls", "tsgo", "biome", "deno", "vue-language-server"]
		}
	},
	"lsp": {
		"deno": { "settings": { "deno": { "enable": true } } },
		"vtsls": {
			"initialization_options": {
				// https://github.com/yioneko/vtsls/blob/04c4d90fb4f18dff34d9282cdb7f508aab12cd95/packages/service/configuration.schema.json#L380
				"typescript": {
					"preferences": { "importModuleSpecifier": "non-relative" }
				}
			}
		},
		"dprint": {
			"binary": {
				"path": "bunx",
				"ignore_system_version": false,
				"arguments": ["dprint", "lsp"]
			}
		},
		"json-language-server": {
			"settings": {
				"json": {
					"schemas": [
						{
							"fileMatch": [".attw.json"],
							"url": "https://gist.githubusercontent.com/kjanat/46efa8c04bf3ed10c406d1965c546177/raw/3e85defc22383f8689a130785321d7da37f3677d/attw.schema.json"
						},
						{
							"fileMatch": ["typedoc.json"],
							"url": "https://typedoc.org/schema.json"
						}
					]
				}
			}
		}
	}
}
